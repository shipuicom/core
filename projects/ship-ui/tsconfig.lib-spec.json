{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec",
    "types": ["vitest/globals", "node"],
    "typeRoots": [
      "../../node_modules/@types",
      "../../node_modules"
    ]
  },
  "include": ["**/*.spec.ts", "**/*.d.ts"],
  "exclude": ["node_modules/@types/bun"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
